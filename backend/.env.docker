APP_NAME=SimpleAgentChatTemplate API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/simple_agent_chat

WORKFLOW_ROOT=./workflows
WORKFLOW_STARTER_FILE=email-chat-draft-or-clarify.yaml
WORKFLOW_ORCHESTRATOR_FILE=email-chat-orchestrator-with-subgraph-tool.yaml
WORKFLOW_SUBGRAPH_FILE=hr-warning-email-subgraph.yaml

MODEL_PREFIX=yaml
DEFAULT_CHAT_TITLE=New Conversation

PROVIDER=openai
CUSTOM_API_BASE=
CUSTOM_API_KEY=

CORS_ORIGINS=["http://localhost:5178"]
